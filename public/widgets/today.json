{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.5",
  "body": [
    {
      "type": "Container",
      "style": "emphasis",
      "items": [
        {
          "type": "ColumnSet",
          "columns": [
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "IRONLOG",
                  "weight": "Bolder",
                  "size": "Medium",
                  "color": "Accent"
                },
                {
                  "type": "TextBlock",
                  "text": "${date}",
                  "size": "Small",
                  "isSubtle": true,
                  "spacing": "None"
                }
              ]
            },
            {
              "type": "Column",
              "width": "auto",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "🔥 ${streak} day streak",
                  "weight": "Bolder",
                  "color": "Warning"
                }
              ]
            }
          ]
        },
        {
          "type": "ColumnSet",
          "separator": true,
          "columns": [
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {"type": "TextBlock", "text": "Calories", "isSubtle": true, "size": "Small"},
                {"type": "TextBlock", "text": "${calories} / ${calGoal}", "weight": "Bolder", "spacing": "None"}
              ]
            },
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {"type": "TextBlock", "text": "Protein", "isSubtle": true, "size": "Small"},
                {"type": "TextBlock", "text": "${protein}g", "weight": "Bolder", "spacing": "None", "color": "Accent"}
              ]
            },
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {"type": "TextBlock", "text": "Today's Split", "isSubtle": true, "size": "Small"},
                {"type": "TextBlock", "text": "${split}", "weight": "Bolder", "spacing": "None"}
              ]
            }
          ]
        }
      ]
    }
  ],
  "actions": [
    {
      "type": "Action.OpenUrl",
      "title": "Log Workout",
      "url": "https://ironlog.space/#log_workout"
    },
    {
      "type": "Action.OpenUrl",
      "title": "Open App",
      "url": "https://ironlog.space/"
    }
  ]
}
