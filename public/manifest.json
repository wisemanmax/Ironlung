{
  "id": "/",
  "name": "IRONLOG Fitness Tracker",
  "short_name": "IRONLOG",
  "description": "Complete workout, nutrition, and body tracking — offline-first, privacy-focused, free forever.",
  "start_url": "./",
  "scope": "./",
  "lang": "en",
  "dir": "ltr",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "tabbed", "standalone"],
  "orientation": "portrait",
  "background_color": "#08080d",
  "theme_color": "#00f5a0",
  "categories": ["health", "fitness", "lifestyle"],
  "iarc_rating_id": "",

  "icons": [
    {"src": "icon-192.png", "sizes": "192x192", "type": "image/png", "purpose": "any"},
    {"src": "icon-192.png", "sizes": "192x192", "type": "image/png", "purpose": "maskable"},
    {"src": "icon-512.png", "sizes": "512x512", "type": "image/png", "purpose": "any"},
    {"src": "icon-512.png", "sizes": "512x512", "type": "image/png", "purpose": "maskable"},
    {"src": "icon.svg",     "sizes": "any",     "type": "image/svg+xml", "purpose": "any maskable"}
  ],

  "screenshots": [
    {
      "src": "screenshot-mobile.png",
      "sizes": "1080x1920",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "IRONLOG workout log on mobile"
    },
    {
      "src": "screenshot-desktop.png",
      "sizes": "1280x800",
      "type": "image/png",
      "form_factor": "wide",
      "label": "IRONLOG workout dashboard on desktop"
    }
  ],

  "shortcuts": [
    {
      "name": "Log Workout",
      "short_name": "Workout",
      "description": "Start logging a new workout",
      "url": "./#log_workout",
      "icons": [{"src": "icon-192.png", "sizes": "192x192"}]
    },
    {
      "name": "Log Nutrition",
      "short_name": "Nutrition",
      "description": "Track today's meals and macros",
      "url": "./#log_nutrition",
      "icons": [{"src": "icon-192.png", "sizes": "192x192"}]
    },
    {
      "name": "Weigh In",
      "short_name": "Weigh In",
      "description": "Log body weight and measurements",
      "url": "./#log_body",
      "icons": [{"src": "icon-192.png", "sizes": "192x192"}]
    },
    {
      "name": "AI Coach",
      "short_name": "Coach",
      "description": "View today's adaptive program",
      "url": "./#track_coach",
      "icons": [{"src": "icon-192.png", "sizes": "192x192"}]
    }
  ],

  "launch_handler": {
    "client_mode": ["focus-existing", "auto"]
  },

  "share_target": {
    "action": "./#share_target",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "files": [
        {"name": "image", "accept": ["image/png", "image/jpeg"]}
      ]
    }
  },

  "file_handlers": [
    {
      "action": "./#import",
      "accept": {
        "application/json": [".json"],
        "text/csv": [".csv"]
      }
    }
  ],

  "protocol_handlers": [
    {
      "protocol": "web+ironlog",
      "url": "./#protocol?data=%s"
    }
  ],

  "scope_extensions": [
    {"origin": "https://ironlog.space"},
    {"origin": "https://www.ironlog.space"}
  ],

  "edge_side_panel": {
    "preferred_width": 400
  },

  "widgets": [
    {
      "name": "Today's Summary",
      "description": "Your daily workout, calories, and streak at a glance",
      "tag": "ironlog-today",
      "template": "ironlog-widget",
      "ms_ac_template": "widgets/today.json",
      "data": "widgets/today-data.json",
      "type": "application/json",
      "screenshots": [
        {
          "src": "screenshot-mobile.png",
          "sizes": "1080x1920",
          "label": "IRONLOG today summary widget"
        }
      ],
      "icons": [
        {"src": "icon-192.png", "sizes": "192x192"}
      ],
      "backgrounds": [
        {"color": "#08080d"}
      ]
    }
  ],

  "related_applications": [],
  "prefer_related_applications": false
}
